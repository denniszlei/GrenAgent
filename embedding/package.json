{
  "name": "embedding",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal local vector service, packaged as a single executable via Node.js SEA",
  "main": "app.ts",
  "scripts": {
    "start": "npm run build:bundle && node dist/app.bundle.js",
    "typecheck": "tsc -p tsconfig.json",
    "build:bundle": "node build.mjs",
    "build:sea": "node --build-sea sea-config.json"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.9.0"
  }
}
