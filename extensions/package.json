{
  "name": "pi-extensions-pack",
  "version": "0.1.0",
  "description": "A pack of LobeHub-inspired Pi extensions: knowledge-rag, long-term-memory, web-fetch, image-gen, code-review, multi-agent.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "rag",
    "memory",
    "web",
    "image",
    "code-review",
    "multi-agent"
  ],
  "license": "MIT",
  "pi": {
    "extensions": [
      "./knowledge-rag/index.ts",
      "./long-term-memory/index.ts",
      "./web-fetch/index.ts",
      "./image-gen/index.ts",
      "./code-review/index.ts",
      "./multi-agent/index.ts",
      "./tts/index.ts",
      "./im-gateway/index.ts"
    ]
  },
  "peerDependencies": {
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "typebox": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.43.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "diff": "^9.0.0",
    "tinyglobby": "^0.2.17"
  }
}
